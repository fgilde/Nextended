<UserControl x:Class="Nextended.UI.WPF.Controls.KeyBindSequenceBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Nextended.UI.WPF.Controls"
             mc:Ignorable="d"
             d:DesignHeight="60" d:DesignWidth="500">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <Border Padding="0" BorderThickness="0" Background="Transparent">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ItemsControl Focusable="False" IsTabStop="False"
                          ItemsSource="{Binding Keys, RelativeSource={RelativeSource AncestorType=local:KeyBindSequenceBox}}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="8">
                            <local:KeyBindChanger BorderBrush="Transparent"
                                                  Text=""
                                                  BindingManager="{Binding BindingManager, RelativeSource={RelativeSource AncestorType=local:KeyBindSequenceBox}}"
                                                  WithBorder="False"
                                                  CanRemoveBinding="True"
                                                  InvalidText="+"
                                                  Tag="{Binding}"
                                                  KeyBindChanged="Child_OnKeyBindChanged"
                                                  KeyBind="{Binding Path=., Mode=OneWay}" />
                            <Border BorderBrush="#55808080"
                                    BorderThickness="1"
                                    Cursor="Hand"
                                    Tag="{Binding}"
                                    Visibility="{Binding IsValid, Converter={StaticResource BoolToVis}}"
                                    MouseLeftButtonDown="Remove_Key_Click"
                                    Background="#33808080"
                                    Margin="0,-4,0,0"
                                    ToolTip="Remove"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    MinWidth="10"
                                    MinHeight="10"
                                    CornerRadius="2">
                                <Label Content="&#xE74D;"
                                       Padding="4"
                                       FontSize="10"
                                       FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                       HorizontalContentAlignment="Center"
                                       VerticalContentAlignment="Center" />
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button x:Name="RecordButton"
                    Grid.Column="1"
                    Content="Record sequence"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Right"
                    Padding="8,4"
                    Margin="5,0,10,0"
                    FontSize="12"
                    Click="RecordButton_OnClick" />

            <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                    Margin="8,2,0,0" VerticalAlignment="Top" HorizontalAlignment="Left"
                    Visibility="{Binding HasError, Converter={StaticResource BoolToVis}, RelativeSource={RelativeSource AncestorType=local:KeyBindSequenceBox}}"
                    Background="#CCB00020"
                    Panel.ZIndex="12"
                    CornerRadius="3">
                <Label Content="{Binding ErrorMessage, RelativeSource={RelativeSource AncestorType=local:KeyBindSequenceBox}}"
                       Foreground="White" />
            </Border>
        </Grid>
    </Border>
</UserControl>
