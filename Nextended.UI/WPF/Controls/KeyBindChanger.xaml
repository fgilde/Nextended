<UserControl x:Class="Nextended.UI.WPF.Controls.KeyBindChanger"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Nextended.UI.WPF.Controls"
             Loaded="KeyBindChanger_OnLoaded"
             Unloaded="KeyBindChanger_OnUnloaded"
             mc:Ignorable="d"
             d:DesignWidth="282.5"
             d:DesignHeight="40">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <Border x:Name="MainBorder"
            BorderThickness="0"
            Height="40">
        <Grid x:Name="MainGrid" PreviewMouseRightButtonUp="ContextMenu_OnOpened">
            <Grid.ContextMenu>
                <ContextMenu x:Name="BindContextMenu">
                    <MenuItem x:Name="DeleteMenuItem" Header="Delete binding" Click="DeleteBinding_Click" />
                </ContextMenu>
            </Grid.ContextMenu>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border Background="Transparent">
                <Grid>
                    <Label x:Name="TitleLabel"
                           Padding="2,10,10,10"
                           Content=""
                           VerticalContentAlignment="Center"
                           FontSize="13" />

                    <Border HorizontalAlignment="Right"
                            x:Name="BindButton"
                            Margin="5,7,2,7"
                            BorderBrush="#55808080"
                            BorderThickness="1"
                            Background="#22808080"
                            CornerRadius="6"
                            Cursor="Hand"
                            MouseLeftButtonDown="BindButton_OnClick"
                            MinWidth="70">
                        <Grid>
                            <TextBlock x:Name="DeviceIcon"
                                       Visibility="Collapsed"
                                       Text="&#xE7FC;"
                                       Background="Transparent"
                                       Opacity="0.7"
                                       FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                       Margin="-10,-8,0,0"
                                       FontSize="16"
                                       VerticalAlignment="Top" />
                            <Label x:Name="KeyLabel"
                                   Content=""
                                   FontSize="12"
                                   HorizontalContentAlignment="Center"
                                   VerticalContentAlignment="Center"
                                   Padding="10,2,10,2" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Label Grid.Column="1"
                   Visibility="{Binding ShowTimeEdit, RelativeSource={RelativeSource AncestorType=local:KeyBindChanger}, Converter={StaticResource BoolToVis}}"
                   Content="&#xEC92;"
                   Cursor="Hand"
                   Background="Transparent"
                   FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                   ToolTip="Configure min hold time"
                   FontSize="11"
                   Margin="-6,10,4,0"
                   HorizontalAlignment="Right"
                   MouseLeftButtonUp="ConfigureMinTimeLabel_OnClick"
                   VerticalAlignment="Center">
                <Label.Style>
                    <Style TargetType="Label">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasTimeValue, RelativeSource={RelativeSource AncestorType=local:KeyBindChanger}}" Value="True">
                                <Setter Property="Foreground" Value="OrangeRed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Label.Style>
            </Label>

            <Popup x:Name="TimeSliderPopup"
                   Placement="Mouse"
                   StaysOpen="False"
                   AllowsTransparency="True">
                <Border Background="#F0303030"
                        BorderBrush="#55808080"
                        CornerRadius="8"
                        MinWidth="300"
                        BorderThickness="1"
                        Padding="12">
                    <StackPanel>
                        <DockPanel>
                            <TextBlock x:Name="MinTimeTitle" Foreground="White" Text="Min hold time (seconds)" />
                            <TextBlock x:Name="MinTimeValueText" Foreground="White" Text="0.0"
                                       DockPanel.Dock="Right" HorizontalAlignment="Right" />
                        </DockPanel>
                        <Slider x:Name="MinTimeSlider"
                                Margin="0,8,0,0"
                                Minimum="0"
                                Maximum="5"
                                TickFrequency="0.1"
                                IsSnapToTickEnabled="True"
                                ValueChanged="MinTimeSlider_OnValueChanged" />
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>
    </Border>
</UserControl>
